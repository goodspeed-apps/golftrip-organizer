+  // DisabledAppController and OTA can never apply.
+  // See hermes#1966, expo#44356/44606/44680.
   [EXAppDefines load:@{
-#if DEBUG
-    @"APP_DEBUG": @(YES),
-#else
     @"APP_DEBUG": @(NO),
-#endif
