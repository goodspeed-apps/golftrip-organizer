+// iOS 26 PAC workaround (TPL-030): the embedded app.manifest lists
+          // assets (e.g. LogBox PNGs) that our DEV=false Debug-config IPA
+          // doesn't actually ship. On first launch, the asset-reconcile loop
+          // hits this branch and asserts because neither the Documents
+          // directory nor the embedded bundle has the file. Downgrade to a
+          // logged warning — the `if let contents` below already skips
+          // appending nil-content assets gracefully, so dropping the assert
+          // is safe; we lose the (dev-only LogBox) image at runtime.
+          if contents == nil {
+            self.logger.warn(message: "AppLoader: existing asset \(existingAsset.filename) not found on disk or in embedded bundle; skipping (likely stripped by DEV=false production bundle).")
           }
           if let contents = contents {
