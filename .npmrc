ignore-scripts=true
engine-strict=true
strict-peer-dependencies=true
# DevAgent's dependency gate adds packages (e.g. @expo-google-fonts/*) to
# package.json after this lockfile was generated. pnpm defaults frozen-lockfile
# to true in CI (EAS Build), so a drifted lockfile fails the install with
# ERR_PNPM_OUTDATED_LOCKFILE and the app never builds. Allow the install to
# update the lockfile on drift instead of hard-failing.
frozen-lockfile=false
