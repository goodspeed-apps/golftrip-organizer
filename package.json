{
  "name": "gas-template",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "typecheck": "tsc --noEmit",
    "config:cjs": "esbuild gas.config.ts --format=cjs --platform=node --target=node18 --outfile=gas.config.js",
    "test": "jest --selectProjects smoke",
    "test:watch": "jest --watch",
    "test:all": "jest --ci --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write '**/*.{ts,tsx,json}'",
    "clean": "rm -rf node_modules .expo dist coverage",
    "release": "node scripts/release.mjs",
    "security": "node scripts/security-local.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:licenses": "license-checker --production --failOn 'GPL;AGPL;LGPL;CC-BY-SA' --excludePackages 'node-forge@1.4.0'",
    "check-bundle": "node scripts/check-bundle-size.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "gen-types": "./scripts/gen-types.sh",
    "check-release-notes": "node scripts/check-release-notes.mjs",
    "submit:store": "node scripts/submit-store.mjs",
    "prepare": "husky",
    "screenshots": "node scripts/generate-screenshots.mjs",
    "postinstall": "patch-package",
    "eas-build-post-install": "npx patch-package",
    "verify-patches": "bash ./scripts/verify-patches.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "2.106.0",
    "expo": "55.0.24",
    "expo-apple-authentication": "~55.0.13",
    "expo-application": "~55.0.15",
    "expo-asset": "~55.0.17",
    "expo-auth-session": "~55.0.16",
    "expo-build-properties": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.20",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-localization": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-sensors": "~55.0.15",
    "expo-sharing": "~55.0.19",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-store-review": "~55.0.14",
    "expo-system-ui": "~55.0.18",
    "expo-tracking-transparency": "~55.0.14",
    "expo-updates": "55.0.22",
    "expo-web-browser": "~55.0.16",
    "i18next": "^23.7.0",
    "lucide-react-native": "^0.475.0",
    "nativewind": "^4.0.0",
    "posthog-react-native": "~3.3.0",
    "react": "19.2.0",
    "react-error-boundary": "^4.0.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^14.0.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^9.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.2",
    "expo-task-manager": "~55.0.16",
    "expo-background-fetch": "~55.0.16",
    "expo-screen-capture": "~55.0.14",
    "@stripe/stripe-react-native": "0.63.0",
    "expo-modules-core": "~55.0.25"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/react-native": "14.0.0-rc.2",
    "@types/jest": "29.5.14",
    "@types/node": "^25.9.0",
    "@types/react": "~19.2.10",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-preset-expo": "55.0.21",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-circus": "^30.4.2",
    "jest-config": "^30.4.2",
    "jest-expo": "~55.0.0",
    "license-checker": "^25.0.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "react-dom": "19.2.0",
    "react-native-web": "^0.21.2",
    "sharp": "^0.34.5",
    "storybook": "^8.6.18",
    "test-renderer": "^1",
    "ts-jest": "^29.4.0",
    "typescript": "~5.9.2",
    "vite": "^6.4.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "smoke",
        "testMatch": [
          "<rootDir>/__tests__/smoke.test.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json",
              "isolatedModules": true
            }
          ]
        }
      },
      {
        "displayName": "lib",
        "testMatch": [
          "<rootDir>/__tests__/lib/*.test.ts",
          "<rootDir>/__tests__/lib/*.test.tsx"
        ],
        "setupFiles": [
          "<rootDir>/__tests__/globals.js"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json",
              "isolatedModules": true
            }
          ],
          "^.+\\.jsx?$": "babel-jest"
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(.pnpm|expo|@expo|@react-native|@sentry|react-native|expo-modules-core|posthog-react-native|i18next|react-i18next|lucide-react-native|react-native-purchases))"
        ],
        "moduleNameMapper": {
          "^expo-modules-core$": "<rootDir>/__tests__/__mocks__/expo-modules-core.js",
          "^expo-constants$": "<rootDir>/__tests__/__mocks__/expo-constants.js",
          "^expo-device$": "<rootDir>/__tests__/__mocks__/expo-device.js",
          "^react-native$": "<rootDir>/__tests__/__mocks__/react-native.js",
          "^@sentry/react-native$": "<rootDir>/__tests__/__mocks__/@sentry/react-native.js",
          "^nativewind/jsx-runtime$": "<rootDir>/__tests__/__mocks__/nativewind-jsx-runtime.js",
          "^nativewind$": "<rootDir>/__tests__/__mocks__/nativewind.js",
          "^@/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "hooks",
        "testMatch": [
          "<rootDir>/__tests__/hooks/*.test.ts",
          "<rootDir>/__tests__/hooks/*.test.tsx"
        ],
        "setupFiles": [
          "<rootDir>/__tests__/globals.js"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/__tests__/setup.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json",
              "isolatedModules": true
            }
          ],
          "^.+\\.jsx?$": "babel-jest"
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(.pnpm|expo|@expo|@react-native|@sentry|react-native|expo-modules-core|posthog-react-native|i18next|react-i18next|lucide-react-native|react-native-purchases))"
        ],
        "moduleNameMapper": {
          "^expo-modules-core$": "<rootDir>/__tests__/__mocks__/expo-modules-core.js",
          "^expo-constants$": "<rootDir>/__tests__/__mocks__/expo-constants.js",
          "^expo-device$": "<rootDir>/__tests__/__mocks__/expo-device.js",
          "^react-native$": "<rootDir>/__tests__/__mocks__/react-native.js",
          "^@sentry/react-native$": "<rootDir>/__tests__/__mocks__/@sentry/react-native.js"
        }
      },
      {
        "displayName": "services",
        "testMatch": [
          "<rootDir>/__tests__/services/*.test.ts"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/__tests__/setup.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json",
              "isolatedModules": true
            }
          ]
        },
        "moduleNameMapper": {
          "^expo-image-manipulator$": "<rootDir>/__tests__/__mocks__/expo-image-manipulator.js",
          "^expo-image-picker$": "<rootDir>/__tests__/__mocks__/expo-image-picker.js",
          "^expo-apple-authentication$": "<rootDir>/__tests__/__mocks__/expo-apple-authentication.js",
          "^expo-local-authentication$": "<rootDir>/__tests__/__mocks__/expo-local-authentication.js",
          "^expo-secure-store$": "<rootDir>/__tests__/__mocks__/expo-secure-store.js",
          "^expo-router$": "<rootDir>/__tests__/__mocks__/expo-router.js",
          "^expo-notifications$": "<rootDir>/__tests__/__mocks__/expo-notifications.js",
          "^expo-device$": "<rootDir>/__tests__/__mocks__/expo-device.js",
          "^react-native$": "<rootDir>/__tests__/__mocks__/react-native.js",
          "^@/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "components",
        "testMatch": [
          "<rootDir>/__tests__/components/*.test.ts",
          "<rootDir>/__tests__/components/*.test.tsx",
          "<rootDir>/__tests__/components/**/*.test.ts",
          "<rootDir>/__tests__/components/**/*.test.tsx"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/__tests__/setup.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "jsx": "react-jsx",
                "jsxImportSource": "nativewind",
                "strict": true,
                "esModuleInterop": true,
                "module": "commonjs"
              },
              "isolatedModules": true
            }
          ],
          "^.+\\.jsx?$": "babel-jest"
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(.pnpm|expo|@expo|@react-native|@sentry|react-native|expo-modules-core|nativewind|react-native-css-interop|posthog-react-native|i18next|react-i18next|lucide-react-native|react-native-purchases))"
        ],
        "moduleNameMapper": {
          "^expo-modules-core$": "<rootDir>/__tests__/__mocks__/expo-modules-core.js",
          "^expo-constants$": "<rootDir>/__tests__/__mocks__/expo-constants.js",
          "^expo-device$": "<rootDir>/__tests__/__mocks__/expo-device.js",
          "^expo-updates$": "<rootDir>/__tests__/__mocks__/expo-updates.js",
          "^@sentry/react-native$": "<rootDir>/__tests__/__mocks__/@sentry/react-native.js",
          "^nativewind/jsx-runtime$": "<rootDir>/__tests__/__mocks__/nativewind-jsx-runtime.js",
          "^nativewind$": "<rootDir>/__tests__/__mocks__/nativewind.js",
          "^react-native$": "<rootDir>/__tests__/__mocks__/react-native.js",
          "^@/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "app",
        "testMatch": [
          "<rootDir>/__tests__/app/*.test.ts",
          "<rootDir>/__tests__/app/*.test.tsx",
          "<rootDir>/__tests__/app/**/*.test.ts",
          "<rootDir>/__tests__/app/**/*.test.tsx"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/__tests__/setup.ts",
          "<rootDir>/__tests__/setup.app.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "jsx": "react-jsx",
                "jsxImportSource": "nativewind",
                "strict": true,
                "esModuleInterop": true,
                "module": "commonjs"
              },
              "isolatedModules": true
            }
          ],
          "^.+\\.jsx?$": "babel-jest"
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(.pnpm|expo|@expo|@react-native|@sentry|react-native|expo-modules-core|nativewind|react-native-css-interop|posthog-react-native|i18next|react-i18next|lucide-react-native|react-native-purchases))"
        ],
        "moduleNameMapper": {
          "^expo-modules-core$": "<rootDir>/__tests__/__mocks__/expo-modules-core.js",
          "^expo-constants$": "<rootDir>/__tests__/__mocks__/expo-constants.js",
          "^expo-device$": "<rootDir>/__tests__/__mocks__/expo-device.js",
          "^expo-updates$": "<rootDir>/__tests__/__mocks__/expo-updates.js",
          "^@sentry/react-native$": "<rootDir>/__tests__/__mocks__/@sentry/react-native.js",
          "^nativewind/jsx-runtime$": "<rootDir>/__tests__/__mocks__/nativewind-jsx-runtime.js",
          "^nativewind$": "<rootDir>/__tests__/__mocks__/nativewind.js",
          "^react-native$": "<rootDir>/__tests__/__mocks__/react-native.js",
          "^@/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "edge-functions",
        "testMatch": [
          "<rootDir>/supabase/functions/**/__tests__/*.test.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowImportingTsExtensions": true,
                "noEmit": true,
                "esModuleInterop": true,
                "strict": true
              },
              "diagnostics": {
                "ignoreCodes": [
                  "TS2307",
                  "TS2304"
                ]
              },
              "isolatedModules": true
            }
          ]
        },
        "moduleNameMapper": {
          "^https://esm\\.sh/@supabase/supabase-js@2$": "@supabase/supabase-js",
          "^https://esm\\.sh/.*$": "<rootDir>/supabase/functions/_shared/__mocks__/esm-sh-noop.js",
          "^(.*)\\.ts$": "$1"
        }
      },
      {
        "displayName": "scripts",
        "testMatch": [
          "<rootDir>/__tests__/scripts/*.test.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json",
              "isolatedModules": true
            }
          ]
        },
        "setupFiles": [
          "<rootDir>/__tests__/globals.js"
        ]
      }
    ],
    "coverageThreshold": {
      "global": {
        "statements": 60,
        "branches": 50,
        "functions": 55,
        "lines": 60
      }
    }
  },
  "peerDependencies": {
    "jail-monkey": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "jail-monkey": {
      "optional": true
    }
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.10",
    "tar": "^6.2.1",
    "cacache": "^20.0.4",
    "postcss": "^8.5.10",
    "@tootallnate/once": "^3.0.1",
    "jsdom": "^26.1.0",
    "http-proxy-agent": "^7.0.2",
    "jest-environment-jsdom": "^30.0.0",
    "tmp": "^0.2.6",
    "ajv": "^8.12.0"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": "^0.8.10",
      "tar": "^6.2.1",
      "cacache": "^20.0.4",
      "postcss": "^8.5.10",
      "@tootallnate/once": "^3.0.1",
      "jsdom": "^26.1.0",
      "http-proxy-agent": "^7.0.2",
      "jest-environment-jsdom": "^30.0.0",
      "tmp": "^0.2.6"
    }
  },
  "private": true,
  "expo": {
    "autolinking": {
      "exclude": [
        "react-native-owl"
      ]
    }
  }
}
