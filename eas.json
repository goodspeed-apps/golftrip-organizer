{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "node": "22.13.0",
      "ios": {
        "simulator": false,
        "image": "macos-sequoia-15.6-xcode-26.2",
        "buildConfiguration": "Release",
        "resourceClass": "medium"
      },
      "android": {
        "resourceClass": "medium"
      },
      "env": {
        "EXPO_PUBLIC_RELEASE_CHANNEL": "preview"
      }
    },
    "preview-sim": {
      "distribution": "internal",
      "channel": "preview",
      "node": "22.13.0",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_RELEASE_CHANNEL": "preview"
      }
    },
    "staging": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "staging",
      "node": "22.13.0",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2",
        "buildConfiguration": "Release",
        "resourceClass": "medium"
      },
      "android": {
        "resourceClass": "medium"
      },
      "env": {
        "EXPO_PUBLIC_RELEASE_CHANNEL": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "node": "22.13.0",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2",
        "buildConfiguration": "Release",
        "resourceClass": "medium"
      },
      "android": {
        "resourceClass": "medium"
      },
      "env": {
        "EXPO_PUBLIC_RELEASE_CHANNEL": "production"
      }
    }
  },
  "submit": {
    "preview": {},
    "staging": {
      "ios": {
        "appleId": "$ASC_APPLE_ID",
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "$ASC_APPLE_ID",
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID",
        "ascApiKeyPath": "$ASC_API_KEY_PATH",
        "ascApiKeyId": "$ASC_API_KEY_ID",
        "ascApiKeyIssuerId": "$ASC_API_KEY_ISSUER_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "production"
      }
    }
  }
}
