# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# RevenueCat (in-app purchases)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_your_android_key

# PostHog (analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_GOODSPEED_APP_ID=

# Google OAuth (only if features.auth.google is enabled)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id

# Sentry (crash reporting)
EXPO_PUBLIC_SENTRY_DSN=https://your_key@your_org.ingest.sentry.io/your_project_id

# EAS
EAS_PROJECT_ID=your_eas_project_id

# Edge-Functions-only — used for CORS origin allowlist
APP_URL=https://your-app-domain.example
DASHBOARD_URL=https://your-dashboard.example

# ─── Async Backbone (cluster 1) ────────────────────────────────────────
# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
# Expo Push (optional; only needed for "enhanced send" allotment)
EXPO_ACCESS_TOKEN=
# Shared secret used by pg_cron and server-to-server admin callers.
# Sent as `Authorization: Bearer <CRON_SECRET>` to job-worker and adminHandler
# endpoints. Set in Supabase project secrets (supabase secrets set CRON_SECRET=...).
CRON_SECRET=
# Public URL for the Supabase Functions runtime (used by pg_cron)
SUPABASE_FUNCTIONS_URL=

# Sentry (cluster 2)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
DEPLOY_ENV=production

# ─── OAuth Token Encryption (cluster 4) ──┬──────────────────────
# 64 hex characters (32 bytes) generated with: openssl rand -hex 32
# Required by oauth-save-connection and oauth-get-token edge functions.
# Must be set in Supabase Functions secrets (supabase secrets set OAUTH_ENCRYPTION_KEY=

# ─── LLM Providers (cluster 5) ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OAUTH_ENCRYPTION_KEY=
